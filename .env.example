# Supabase configuration
# Get these from your Supabase dashboard: Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# HERE Maps (free tier — sign up at https://platform.here.com)
VITE_HERE_API_KEY=your-here-api-key-here

# Google Maps Platform (free monthly caps per API — billing account required)
# Get a key at https://console.cloud.google.com → enable "Places API (New)"
# Restrict it to your domains and set daily quota caps — see BACKLOG.md notes
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
